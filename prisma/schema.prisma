generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  UserID     Int      @id @default(autoincrement())
  Name       String
  Surname    String
  Email      String   @unique
  Password   String
  Username   String?
  Phone      String
  Created_At DateTime @default(now())
  Update_At  DateTime @default(now())
  Verified   Boolean

  RoleID Int
  Role   Role @relation(fields: [RoleID], references: [RoleID])

  Ilanlar             Ilan[]
  Yorumlar            Yorum[]
  Favoriler           Favori[]
  EvArkadasiIlanlar   EvArkadasiIlan[]
  EvArkadasiYorumlar  EvArkadasiYorum[]
  EvArkadasiFavoriler EvArkadasiFavori[]
}

model Role {
  RoleID Int    @id @default(autoincrement())
  Name   String @unique

  Users User[]
}

model Ilan {
  IlanId      Int            @id @default(autoincrement())
  Fiyat       Float
  OdaSayisi   String
  BinaYasi    Int
  Hakkinda    String
  Status      String
  CreatedAt   DateTime       @default(now())
  UpdateAt    DateTime       @updatedAt
  UserID      Int
  IlanType    String
  IlanBaslık String
  User        User           @relation(fields: [UserID], references: [UserID])
  IlId        Int
  Il          Il             @relation(fields: [IlId], references: [IlId])
  IlceId      Int
  Ilce        Ilce           @relation(fields: [IlceId], references: [IlceId])
  MahalleId   Int
  Mahalle     Mahalle        @relation(fields: [MahalleId], references: [MahalleId])
  Yorumlar    Yorum[]
  Favoriler   Favori[]
  Ozellikler  IlanOzellik[]
  Fotograf    IlanFotograf[]
}

model Yorum {
  YorumId      Int      @id @default(autoincrement())
  YorumContent String
  Puan         Int
  CreateAt     DateTime @default(now())
  IlanId       Int
  Ilan         Ilan     @relation(fields: [IlanId], references: [IlanId], onDelete: Cascade)
  UserId       Int
  User         User     @relation(fields: [UserId], references: [UserID], onDelete: Cascade)
}

model Ozellik {
  OzellikId            Int                 @id @default(autoincrement())
  OzellikAdi           String
  Ilanlar              IlanOzellik[]
  EvArkadasiOzellikler EvArkadasiOzellik[]
}

model IlanOzellik {
  IlanOzellikId Int     @id @default(autoincrement())
  IlanId        Int
  Ilan          Ilan    @relation(fields: [IlanId], references: [IlanId], onDelete: Cascade)
  OzellikId     Int
  Ozellik       Ozellik @relation(fields: [OzellikId], references: [OzellikId], onDelete: Cascade)

  @@unique([IlanId, OzellikId])
}

model Favori {
  FavoriId  Int      @id @default(autoincrement())
  CreatedAt DateTime @default(now())
  IlanId    Int
  Ilan      Ilan     @relation(fields: [IlanId], references: [IlanId], onDelete: Cascade)
  UserId    Int
  User      User     @relation(fields: [UserId], references: [UserID], onDelete: Cascade)

  @@unique([UserId, IlanId])
}

model Il {
  IlId              Int              @id
  IlAdi             String
  Ilceler           Ilce[]
  Ilanlar           Ilan[]
  EvArkadasiIlanlar EvArkadasiIlan[]
}

model Ilce {
  IlceId          Int              @id @default(autoincrement())
  IlceAdi         String
  IlId            Int
  Il              Il               @relation(fields: [IlId], references: [IlId])
  Mahalleler      Mahalle[]
  Ilanlar         Ilan[]
  evArkadasiIlans EvArkadasiIlan[]
}

model Mahalle {
  MahalleId         Int              @id @default(autoincrement())
  MahalleAdi        String
  IlceId            Int
  Ilce              Ilce             @relation(fields: [IlceId], references: [IlceId])
  Ilanlar           Ilan[]
  EvArkadasiIlanlar EvArkadasiIlan[]
}

model IlanFotograf {
  Ilan_Foto_Id Int      @id @default(autoincrement())
  ImgUrl       String
  IsCover      Boolean  @default(false)
  CreatedAt    DateTime @default(now())
  IlanId       Int
  Ilan         Ilan     @relation(fields: [IlanId], references: [IlanId], onDelete: Cascade)
}

model EvArkadasiIlan {
  EvArkadasiIlanId Int      @id @default(autoincrement())
  Baslik           String
  Aciklama         String
  EvTipi           String
  EvArkadasiSayisi Int
  Butce            Float
  TasinmaTarihi    DateTime
  CreatedAt        DateTime @default(now())
  UpdatedAt        DateTime @updatedAt
  Status           String
  UserId           Int
  User             User     @relation(fields: [UserId], references: [UserID])

  IlId       Int
  Il         Il                  @relation(fields: [IlId], references: [IlId])
  IlceId     Int
  Ilce       Ilce                @relation(fields: [IlceId], references: [IlceId])
  MahalleId  Int
  Mahalle    Mahalle             @relation(fields: [MahalleId], references: [MahalleId])
  Fotograf   EvArkadasiFoto[]
  Ozellikler EvArkadasiOzellik[]
  Kurallar   EvKurallari[]
  Yorumlar   EvArkadasiYorum[]
  Favoriler  EvArkadasiFavori[]
}

model EvArkadasiFoto {
  FotoId           Int            @id @default(autoincrement())
  ImgUrl           String
  IsCover          Boolean        @default(false)
  EvArkadasiIlanId Int
  Ilan             EvArkadasiIlan @relation(fields: [EvArkadasiIlanId], references: [EvArkadasiIlanId], onDelete: Cascade)
  CreatedAt        DateTime       @default(now())
}

model EvArkadasiOzellik {
  Id               Int            @id @default(autoincrement())
  EvArkadasiIlanId Int
  Ilan             EvArkadasiIlan @relation(fields: [EvArkadasiIlanId], references: [EvArkadasiIlanId], onDelete: Cascade)
  OzellikId        Int
  Ozellik          Ozellik        @relation(fields: [OzellikId], references: [OzellikId])

  @@unique([EvArkadasiIlanId, OzellikId])
}

model EvKurallari {
  KuralId          Int            @id @default(autoincrement())
  KuralText        String
  EvArkadasiIlanId Int
  Ilan             EvArkadasiIlan @relation(fields: [EvArkadasiIlanId], references: [EvArkadasiIlanId], onDelete: Cascade)
}

model EvArkadasiYorum {
  YorumId          Int            @id @default(autoincrement())
  YorumContent     String
  Puan             Int
  CreatedAt        DateTime       @default(now())
  UserId           Int
  User             User           @relation(fields: [UserId], references: [UserID], onDelete: Cascade)
  EvArkadasiIlanId Int
  Ilan             EvArkadasiIlan @relation(fields: [EvArkadasiIlanId], references: [EvArkadasiIlanId], onDelete: Cascade)
}

model EvArkadasiFavori {
  FavoriId         Int            @id @default(autoincrement())
  CreatedAt        DateTime       @default(now())
  UserId           Int
  User             User           @relation(fields: [UserId], references: [UserID], onDelete: Cascade)
  EvArkadasiIlanId Int
  Ilan             EvArkadasiIlan @relation(fields: [EvArkadasiIlanId], references: [EvArkadasiIlanId], onDelete: Cascade)

  @@unique([UserId, EvArkadasiIlanId])
}
